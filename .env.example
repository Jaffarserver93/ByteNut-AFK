# ============================================================
# ByteNut AFK Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# -----------------------------------------------
# Bot Configuration
# -----------------------------------------------

# URL of the login page (where the bot will enter credentials)
LOGIN_URL=https://www.bytenut.com/login

# URL of the target page to stay active on after login
TARGET_URL=https://www.bytenut.com/dashboard

# Your ByteNut account credentials
BOT_USERNAME=your_username_here
BOT_PASSWORD=your_password_here

# -----------------------------------------------
# Server Ports
# -----------------------------------------------

# Port for the API server (bot engine + REST API)
API_PORT=3000

# Port for the dashboard web UI
DASHBOARD_PORT=8080

# -----------------------------------------------
# Session Security
# -----------------------------------------------

# Secret key for session signing (use a long random string)
SESSION_SECRET=change_this_to_a_long_random_secret_string
